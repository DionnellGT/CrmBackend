# ============================================================
# DESARROLLO LOCAL (docker-compose con Postgres + Redis locales)
# ============================================================
# Si usas `docker compose up`, DATABASE_URL y DIRECT_URL se
# sobreescriben automáticamente en docker-compose.yml — no hace
# falta que los edites aquí para desarrollo.
#
# Si corres el backend SIN Docker (npm run start:dev directo),
# entonces sí necesitas tener un Postgres local corriendo y
# apuntar aquí manualmente, ej:
DATABASE_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"
DIRECT_URL="postgresql://crm:crm@localhost:5432/crm?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

# App
PORT=3000

# ============================================================
# Para producción (Neon) usa .env.production.example como base
# ============================================================

