# ============================================================
# PRODUCCIÓN — Neon Postgres
# Ve a tu proyecto en Neon > Dashboard > Connection Details
# ============================================================

# Pooled connection (para runtime de la app, usa PgBouncer)
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/crm?sslmode=require"

# Direct connection (necesaria para "prisma migrate deploy", sin pooler)
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/crm?sslmode=require"

# Redis en producción (ej: Upstash, Redis Cloud, o el que uses)
REDIS_HOST="your-redis-host"
REDIS_PORT=6379

# JWT
JWT_SECRET="usa-un-secreto-largo-y-aleatorio-distinto-al-de-dev"
JWT_EXPIRES_IN="1d"

# App
PORT=3000
